{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Browhere",
  "version": "0.1.0",
  "identifier": "com.browhere.desktop-search",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Browhere",
        "width": 1100,
        "height": 760,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
