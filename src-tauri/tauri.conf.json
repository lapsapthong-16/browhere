{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Browhere",
  "version": "0.1.0",
  "identifier": "com.browhere.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "placeholder-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Browhere",
        "width": 1180,
        "height": 820,
        "minWidth": 880,
        "minHeight": 640
      },
      {
        "label": "search",
        "title": "Browhere Search",
        "url": "/search",
        "width": 760,
        "height": 520,
        "minWidth": 520,
        "minHeight": 360,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Productivity",
    "icon": ["icons/icon.png"],
    "shortDescription": "Local-first semantic file search",
    "longDescription": "Browhere indexes approved local folders and lets you search files by meaning from a macOS desktop app."
  }
}
